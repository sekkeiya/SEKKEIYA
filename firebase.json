{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "sekkeiya",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/login",
        "destination": "/index.html"
      },
      {
        "source": "/signup",
        "destination": "/index.html"
      },
      {
        "source": "/app/share",
        "destination": "/app/share/index.html"
      },
      {
        "source": "/app/share/",
        "destination": "/app/share/index.html"
      },
      {
        "source": "/app/share/**",
        "destination": "/app/share/index.html"
      },
      {
        "source": "/app/layout",
        "destination": "/app/layout/index.html"
      },
      {
        "source": "/app/layout/",
        "destination": "/app/layout/index.html"
      },
      {
        "source": "/app/layout/**",
        "destination": "/app/layout/index.html"
      },
      {
        "source": "**",
        "function": "web",
        "region": "asia-northeast1"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}