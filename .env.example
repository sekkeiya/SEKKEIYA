# Copy to .env.local and fill in real values. .env.local is gitignored.

# App origin (dev)
VITE_APP_ORIGIN=http://localhost:5173

# Firebase Admin SDK service account (path to JSON key, server-side only)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-admin-key.json

# Google Generative Language (Gemini) API key — billable secret
GEMINI_API_KEY=your-gemini-api-key

# Google Calendar connector (desktop / installed-app OAuth)
# See packages/desktop-shell/src/features/connectors/google/googleCalendarOAuth.ts
VITE_GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
VITE_GOOGLE_REDIRECT_URI=http://127.0.0.1:14205
