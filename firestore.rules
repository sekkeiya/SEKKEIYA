rules_version = '2';
service cloud.firestore {

  /* ========= 共通ヘルパ ========= */
  function isSignedIn() {
    return request.auth != null;
  }

  function isVerified() {
    return isSignedIn() && request.auth.token.email_verified == true;
  }

  // 管理者判定（メールベース。クライアントの ADMIN_EMAILS と一致させること）
  function isAdminUser() {
    return isSignedIn() && request.auth.token.email in [
      'hello@sekkeiya.com'
    ];
  }

  // 可視性（後方互換）
  function isPublic(data) {
    return (data.get('visibility', '') == 'public') ||
           (data.get('isPublic', false) == true && !(data.get('isPrivate', false) == true));
  }

  function isDocPublic(d) {
    return d is map && isPublic(d);
  }

  // モデルの所有者判定（フィールド揺れを吸収）
  function isModelOwnerData(d) {
    return isSignedIn() && d is map && (
      d.createdBy == request.auth.uid ||
      d.createdByUid == request.auth.uid ||
      d.ownerId == request.auth.uid ||
      d.owner == request.auth.uid ||
      d.ownerUid == request.auth.uid ||
      (d.ownerRef is map && d.ownerRef.uid == request.auth.uid) ||
      d.author == request.auth.uid ||
      d.authorUid == request.auth.uid ||
      d.userId == request.auth.uid ||
      d.uid == request.auth.uid
    );
  }

  // モデルが「共有ユーザー」に公開されているか（チームボード用）
  function isModelSharedUserData(d) {
    return isSignedIn() && d is map && (
      (d.sharedUserIds is list && request.auth.uid in d.sharedUserIds) ||
      (d.editorIds is list      && request.auth.uid in d.editorIds) ||
      (d.collaborators is list  && request.auth.uid in d.collaborators)
    );
  }

  /* ---- 記事の所有者判定（map を受け取る） ---- */
  function isArticleOwnerData(d) {
    return isSignedIn() && d is map && (
      d.ownerId == request.auth.uid ||
      d.owner == request.auth.uid ||
      d.createdBy == request.auth.uid ||
      d.authorUid == request.auth.uid ||
      (d.ownerRef is map && d.ownerRef.uid == request.auth.uid)
    );
  }

  /* ---- タグ配列の簡易バリデーション ---- */
  function validTagsField() {
    return (request.resource.data.tags is list) &&
           (request.resource.data.tags.size() <= 20);
  }






  /* ===== usernames ===== */
  function usernameDoc(handleLower) {
    return get(/databases/$(database)/documents/usernames/$(handleLower));
  }
  function isUsernameOwnedByRequester(handleLower) {
    return isSignedIn() && usernameDoc(handleLower).data.uid == request.auth.uid;
  }

  // 管理者判定：カスタムクレーム admin か、公式メールのホワイトリスト
  function isAdmin() {
    return isSignedIn() && (
      request.auth.token.admin == true ||
      request.auth.token.email in [
        "hello@sekkeiya.com"
      ]
    );
  }

  /* ===========================================
   * ★ RideGallery 用ヘルパ
   * =========================================*/
  // users/{uid}.rideGalleryRole を参照してロール判定
  function rideGalleryUserRole(uid) {
    return get(/databases/$(database)/documents/users/$(uid)).data.rideGalleryRole;
  }

  function isRideGalleryCreator() {
    return isSignedIn() && rideGalleryUserRole(request.auth.uid) == "creator";
  }

  // users/{userId} 更新時に、rideGalleryRole の変更を制御
  // クライアントから自分で "creator" を名乗るのだけ禁止する。
  // それ以外（null→viewer, viewer→pending など）はすべて許可。
  // ※"creator" への昇格は Cloud Functions / Admin SDK 側で行う想定。
  function isRideGalleryRoleTransitionOK() {
    return !(
      request.resource.data.diff(resource.data).affectedKeys().hasAny(['rideGalleryRole']) &&
      request.resource.data.rideGalleryRole == "creator"
    );
  }

  match /databases/{database}/documents {

    /* ======================================================
     * ★ メインコレクション群
     * ==================================================== */

    /* ======================================================
     * ★ Unified Boards (New Schema v2) - DELETED
     * ==================================================== */


    // ----------------------------
    // Materials (user scoped)
    // /materials/{uid}/materials/{materialId}
    // ----------------------------
    match /materials/{userId}/materials/{materialId} {

      // public: 全員OK
      // private: オーナーのみ
      allow read: if isDocPublic(resource.data)
                  || (isSignedIn() && request.auth.uid == userId);

      // 作成: 自分の配下だけ + ownerId整合
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.ownerId == request.auth.uid;

      // 更新/削除: 自分の配下だけ
      allow update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ----------------------------
    // collectionGroup("materials") の読み取り許可
    // どこ階層でも "materials" サブコレクションを読むときに適用される
    // ----------------------------
    match /{path=**}/materials/{materialId} {
      allow read: if isDocPublic(resource.data);
    }

    // ----------------------------
    // collectionGroup("models") の読み取り許可
    // どこ階層でも "models" サブコレクションを読むときに適用される
    // ----------------------------
    match /{path=**}/models/{modelId} {
      allow read: if isDocPublic(resource.data)
                  || isModelOwnerData(resource.data)
                  || isModelSharedUserData(resource.data);
    }

    // ----------------------------
    // collectionGroup("items") の読み取り許可 (SSOT v2)
    // ----------------------------
    match /{path=**}/items/{itemId} {
      allow read: if isDocPublic(resource.data)
                  || isModelOwnerData(resource.data)
                  || isModelSharedUserData(resource.data)
                  // 3DSP プレゼンテーション: 認証済みユーザーは type:'presentation' を読める。
                  // createPresentation のデフォルトが 'public' であり、ギャラリー側で
                  // visibility != 'private' をクライアントフィルターする。
                  // ※ Firestore はクエリフィルター(type=presentation)とルール条件が
                  //   一致しているためコレクショングループクエリを許可する。
                  || (isSignedIn() && resource.data.get('type', '') == 'presentation');
    }

    // ----------------------------
    // collectionGroup("workFiles") の読み取り許可
    // projects/{projectId}/workFiles/{id} を collectionGroup でクエリする
    // 3DSP グローバルスコープ（Presentations フィード / マイプレゼン）で使用
    // ----------------------------
    match /{path=**}/workFiles/{workFileId} {
      allow read: if isSignedIn() && (
        // 公開済み workFile は認証済みユーザー全員が閲覧可能（Presentationsフィード用）
        resource.data.get('visibility', '') == 'public' ||
        // 自分が作成した workFile は自分だけ閲覧可能（マイプレゼン：公開・非公開どちらも）
        resource.data.get('createdBy', '') == request.auth.uid
      );
    }

    // ----------------------------
    // collectionGroup("layouts") の読み取り許可
    // projects/{projectId}/workspaces/{workspaceId}/layouts/{id} を collectionGroup でクエリする
    // 3DSL グローバルスコープ（Layout Hub / My Layouts）で使用
    // ----------------------------
    match /{path=**}/layouts/{layoutId} {
      allow read: if isSignedIn() && (
        // 公開済みレイアウトは認証済みユーザー全員が閲覧可能（global_layouts / global_following_layouts 用）
        resource.data.get('visibility', '') == 'public' ||
        // 自分が所有・作成したレイアウトは非公開でも閲覧可能（my_private_layouts / my_public_layouts 用）
        isModelOwnerData(resource.data)
      );
    }

    // ----------------------------
    // collectionGroup("renders") の読み取り許可
    // projects/{projectId}/workspaces/{workspaceId}/layouts/{planId}/renders/{id}
    // を collectionGroup でクエリする
    // 3DSL My Layouts / Global Layout Hub の Image・Movie タブで使用
    // ----------------------------
    match /{path=**}/renders/{renderId} {
      allow read: if isSignedIn() && (
        // 自分が作成したレンダリング画像は非公開でも閲覧可能（My Layouts 用）
        resource.data.get('createdBy', '') == request.auth.uid ||
        // 公開済みレンダリング画像は認証済みユーザー全員が閲覧可能（グローバルフィード用）
        resource.data.get('visibility', '') == 'public'
      );
      allow write: if isSignedIn() &&
        resource.data.get('createdBy', '') == request.auth.uid;
    }

    /* ---- publicModelIndex ---- */
    match /publicModelIndex/{modelId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    /* ---- plans ---- */
    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    /* ---- modelSets (Set Furniture) ---- */
    match /modelSets/{setId} {
      // 公開セットは認証済みユーザーが閲覧可能、非公開はオーナーのみ
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' ||
        resource.data.ownerId == request.auth.uid
      );
      // 作成: 自分の ownerId でのみ作成可
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      // 更新・削除: オーナーのみ
      allow update, delete: if isSignedIn() &&
        resource.data.ownerId == request.auth.uid;
    }

    /* 公式記事 */
    match /officialArticles/{id} {
      // 公開記事はだれでも読める。下書き・レビュー待ちは管理者のみ。
      allow get, list: if isAdmin() || (resource.data.status == "published");

      // 作成・更新・削除は管理者のみ
      allow create, update, delete: if isAdmin();
    }

    /* AI記者 週次トレンド集計（Cloud Functions admin SDK が書き込み、管理者 UI が読む） */
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions (admin SDK) のみ書き込み可
    }
    match /analytics/{docId}/weeks/{weekId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /* コンテンツ戦略のトピックキュー（管理者のみ。AI記者モード②の入力源）。
       Cloud Functions(admin SDK) も status を更新するが admin SDK はルールを迂回する。 */
    match /topicQueue/{id} {
      allow read, write: if isAdmin();
    }

    /* 専門AI記者の定義（管理者のみ。generateKeywordArticle が人格を読む） */
    match /reporters/{id} {
      allow read, write: if isAdmin();
    }

    /* 記事カテゴリ（公開一覧のフィルタで読むため read は誰でも可、書き込みは管理者のみ） */
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* 設定（AIモデル設定・公式アカウント等）。管理者のみ read/write。Cloud Functions(admin SDK)はルール迂回。 */
    match /config/{doc} {
      allow read, write: if isAdmin();
    }

    /* S.Blog 公開記事の公式サイト向けミラー（/articles「みんなの記事」）。
       read は誰でも可。write は著者本人（authorUid 一致）のみ。 */
    match /communityArticles/{id} {
      allow read: if true;
      allow create, update: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || isAdmin());
    }



    /* ======================================================
     *  🔴 チャット（MVP版）
     * ==================================================== */
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (request.resource.data.members is list)
        && (request.auth.uid in request.resource.data.members);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }


    /* ---- brandTags ---- */
    match /brandTags/{slug} {
      allow read: if true;
      allow write: if false;
    }

    /* ---- tags ---- */
    match /tags/{slug} {
      allow read: if true;
      allow write: if false;
    }

    /* ---- グローバル assets (Global Master Asset Architecture) ---- */
    match /assets/{assetId} {
      allow read: if isPublic(resource.data)
                  || isModelOwnerData(resource.data)
                  || isModelSharedUserData(resource.data);

      allow create: if isSignedIn() && isModelOwnerData(request.resource.data);
      allow update: if isModelOwnerData(resource.data) || isModelOwnerData(request.resource.data);
      allow delete: if isVerified() && isModelOwnerData(resource.data);
    }

    /* ---- グローバル models ---- */
    match /models/{modelId} {
      // 公開 or オーナー or 共有ユーザー
      allow read: if isPublic(resource.data)
                  || isModelOwnerData(resource.data)
                  || isModelSharedUserData(resource.data);

      allow create: if isSignedIn() && isModelOwnerData(request.resource.data);
      allow update: if isModelOwnerData(resource.data) || isModelOwnerData(request.resource.data);
      allow delete: if isVerified() && isModelOwnerData(resource.data);

      match /scenes/{sceneId} {
        function _model() { return get(/databases/$(database)/documents/models/$(modelId)).data; }
        // 公開 or オーナー or 共有ユーザー
        allow read: if isDocPublic(_model())
                    || isModelOwnerData(_model())
                    || isModelSharedUserData(_model());

        // 書き込みは引き続きオーナーのみ
        allow create, update, delete: if isVerified() && isModelOwnerData(_model());
      }

      match /articles/{articleId} {
        function _model() { return get(/databases/$(database)/documents/models/$(modelId)).data; }
        function isModelOwner() { return isModelOwnerData(_model()); }
        function isModelEditor() {
          return request.auth != null
            && (('editorIds' in _model() && request.auth.uid in _model().editorIds) ||
                ('collaborators' in _model() && request.auth.uid in _model().collaborators));
        }
        allow read: if true;
        allow create, update, delete: if isModelOwner() || isModelEditor();
      }
    }



    /* ---- users ---- */
    match /users/{userId} {
      allow read: if true;

      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isVerified() && request.auth.uid == userId;

      // ★ RideGallery のロール変更制御を組み込んだ update
      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          isRideGalleryRoleTransitionOK()
        ) ||
        (
          request.resource.data.keys().hasOnly(["stats"]) &&
          (request.resource.data.stats is map)
        )
      );

      match /following/{targetUserId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /followers/{followerUserId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == followerUserId;
      }

      match /appPreferences/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Research & Memo 個人ボード（アカウントサイト。users/{uid}/research/canvas に1doc）。本人のみ。
      match /research/{researchDocId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /appPreferences/3dss/userVisibility/{targetUserId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /models/{modelId} {
        allow read: if isDocPublic(resource.data)
          || (isSignedIn() && request.auth.uid == userId)
          || isModelSharedUserData(resource.data);

        allow create, update: if isSignedIn() && request.auth.uid == userId
          && (!('tags' in request.resource.data) || validTagsField());

        allow delete: if isVerified() && request.auth.uid == userId;
      }





      /* ---- AI Drive Collections ---- */
      match /driveFolders/{folderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /driveAssets/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- Knowledge / RAG (AI Studio ナレッジ) ----
         書き込みは ingestKnowledge / deleteKnowledgeSource (admin SDK) が担当。
         クライアントは自分のソースの読み取りのみ必要。 */
      match /knowledgeSources/{sourceId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
      match /knowledgeChunks/{chunkId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      /* ---- S.Blog 記事（dsb / 3dsb）----
         本人は自分の記事を読み書き可。公開済み(status=='published')の記事は
         公開サイト/検索向けに誰でも読み取り可（下書きは本人のみ）。 */
      match /blogArticles/{articleId} {
        allow read: if (request.auth != null && request.auth.uid == userId)
                    || resource.data.status == 'published';
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- S.Blog 設定（ユーザー作成カテゴリ等）---- 本人のみ読み書き。 */
      match /blogSettings/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- S.Blog 投稿スケジュール（コンテンツカレンダー）---- 本人のみ読み書き。 */
      match /blogSchedules/{scheduleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- AI Chat Collections ---- */
      match /chatThreads/{threadId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      /* ---- AI Generation Collections ---- */
      match /aiWallet/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
      match /aiJobs/{jobId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if false;
      }



      match /templates/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      /* ---- User Custom Layout Rules ---- */
      match /layout_rules/{ruleKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- User Default Furniture (レイアウト自動配置デフォルト家具) ---- */
      match /furniture_defaults/{categoryKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- User Furniture Sets (デフォルトセット家具) ---- */
      match /furniture_sets/{setId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- Account Site (マイページ＝アカウントサイト本体) ---- */
      // /users/{uid}/site/main。本人のみ編集、公開ページのため読み取りは公開（users 本体と同方針）。
      match /site/{docId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      /* ---- Connectors（外部サービス連携トークン） ---- */
      // /users/{uid}/connectors/{connectorId}
      // アクセストークン・リフレッシュトークンを保存。本人のみ読み書き可。
      match /connectors/{connectorId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      /* ---- Reaction Logs（反応ログ・学習サイクル Phase 1） ---- */
      // /users/{uid}/reactionLogs/{logId}
      // ユーザーの暗黙の反応（表示/クリック/採用/書き直し等）を記録する追記専用ログ。
      // 本人のみ create・読取。update/delete は永久に禁止（layout_generation_logs と同方針）。
      // 横断集計は Cloud Functions（Admin SDK・collectionGroup）が行う。
      match /reactionLogs/{logId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId
          && request.resource.data.schemaVersion is int
          && request.resource.data.surface is string
          && request.resource.data.surface.size() <= 40
          && request.resource.data.action is string
          && request.resource.data.action.size() <= 24
          && request.resource.data.targetType is string
          && (!('label' in request.resource.data) || request.resource.data.label.size() <= 80)
          && request.resource.data.day is string
          && request.resource.data.createdAt == request.time; // serverTimestamp強制＝時刻偽装を防ぐ
        allow update, delete: if false; // 不変・追記専用
      }
    }



    /* ---- layout_generation_logs ---- */
    match /layout_generation_logs/{logId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    /* ---- layout_rules ---- */
    match /layout_rules/{buildingType} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == 'K67Fm1A2fZdAWWAXda83i974XOE3'; // SEKKEIYA管理者のみ
    }
    /* ---- project layout_rules ---- */
    match /projects/{projectId}/layout_rules/{ruleKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }

    /* ---- project furniture_defaults (プロジェクト別デフォルト家具) ---- */
    match /projects/{projectId}/furniture_defaults/{categoryKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }

    /* ---- layout_rules_versions ---- */
    match /layout_rules_versions/{buildingType}/versions/{versionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == 'K67Fm1A2fZdAWWAXda83i974XOE3'; // SEKKEIYA管理者のみ
    }

    /* ---- usernames ---- */
    match /usernames/{handleLower} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(handleLower));
      // 同一ユーザーによる再確保（idempotent な setDoc）は許可。所有者の付け替えは不可。
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    /* ---- publishedSites（公開サイトのスナップショット。Web が認証なしで読む公開コピー） ---- */
    // docId: account = `u__{username}` / project = `p__{username}__{projectId}`。
    // 読み取りは完全公開、書き込み/削除は所有者本人のみ。
    match /publishedSites/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    /* ---- viewerShares（S.Layout 本番プレビュー共有） ---- */
    // docId: ランダム shareId。リンクを知る人がブラウザ（未ログイン含む）で閲覧する公開コピー。
    // 読み取りは private 以外は公開、作成/更新/削除は所有者のみ。
    // 所有者判定 isModelOwnerData は ownerUid / createdByUid 等のフィールド揺れを吸収する。
    match /viewerShares/{shareId} {
      allow read: if resource.data.get('visibility', '') != 'private'
                  || isModelOwnerData(resource.data);
      allow create: if isSignedIn()
                    && isModelOwnerData(request.resource.data);
      allow update, delete: if isModelOwnerData(resource.data);
    }

    /* ---- bookmarkInbox（S.Library ブックマーク受信箱） ---- */
    // ブラウザ拡張→Web(/clip)→ここに1件 create。Desktop アプリが本人分を購読して
    // ローカル S.Library に回収し、回収後に delete する（クラウドには残さない受け渡し用）。
    // 本人(ownerId)のみ作成・読取・削除可。更新は不要なので不可。
    match /bookmarkInbox/{itemId} {
      allow read, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.url is string;
    }

    /* ===========================================
     * ★ RideGallery Rides コレクション
     *    /rideGalleryRides/{rideId}
     * =========================================*/
    match /rideGalleryRides/{rideId} {
      // 誰でも閲覧可能（MVP）。必要になったら visibility で絞る。
      allow read: if true;

      // 作成: creator ロール & ownerId が自分
      allow create: if isRideGalleryCreator()
        && request.resource.data.ownerId == request.auth.uid;

      // 更新・削除: creator 本人 or Admin
      allow update, delete: if
        (isRideGalleryCreator() && resource.data.ownerId == request.auth.uid)
        || isAdmin();
    }

    /* ---- Templates ---- */
    match /officialTemplates/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /publicTemplates/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /* ---- App Global Config ---- */
    match /appGlobalConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* ======================================================
     * ★ Projects (New Root Collection)
     * ==================================================== */
    match /projects/{projectId} {
      // ロールベース権限（docs/15 §4）。roles(uid→role) を正とし、
      // memberIds は roles.keys() と同期した高速判定インデックス。
      // 後方互換: roles 未設定の旧 Pj は ownerId / memberIds にフォールバックする。
      function projRoles() { return resource.data.get('roles', {}); }
      function projRole()  { return projRoles().get(request.auth.uid, ''); }
      function projHasRoles() { return projRoles().size() > 0; }

      function canReadProject() {
        return isSignedIn() && (
          request.auth.uid in resource.data.get('memberIds', []) ||
          request.auth.uid == resource.data.ownerId ||
          isPublic(resource.data)
        );
      }
      // owner = 設定 / 削除 / 公開 / メンバー管理
      function isProjectOwner() {
        return isSignedIn() && (
          projRole() == 'owner' ||
          (!projHasRoles() && request.auth.uid == resource.data.ownerId)
        );
      }
      // owner / editor = 編集（viewer は書き込み不可）
      function canEditProject() {
        return isSignedIn() && (
          projRole() == 'owner' || projRole() == 'editor' ||
          (!projHasRoles() && (
            request.auth.uid == resource.data.ownerId ||
            request.auth.uid in resource.data.get('memberIds', [])
          ))
        );
      }
      // owner 以外が変更してはならない統制フィールド
      function touchesGovernedFields() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['roles','memberIds','ownerId','visibility','isTeam','teamId']);
      }

      // チームプロジェクトはメンバーIDで判定 (teamId クエリが安全に動くよう memberIds を正とする)
      allow read: if canReadProject();
      allow create: if isSignedIn() &&
                    request.resource.data.ownerId == request.auth.uid &&
                    request.auth.uid in request.resource.data.get('memberIds', []);
      // editor は通常編集のみ。roles/公開/所有者などの統制フィールドは owner だけが変更できる。
      allow update: if canEditProject() && (isProjectOwner() || !touchesGovernedFields());
      allow delete: if isProjectOwner();

      match /workspaces/{workspaceId} {
        function parentProject() { 
          let docRef = get(/databases/$(database)/documents/projects/$(projectId));
          return docRef != null ? docRef.data : null;
        }
        function parentProjectAfter() { 
          let docRef = getAfter(/databases/$(database)/documents/projects/$(projectId));
          return docRef != null ? docRef.data : null;
        }

        function canReadWorkspace() {
          let p = parentProject();
          return isSignedIn() && (
            request.auth.uid == p.ownerId ||
            request.auth.uid in p.get('memberIds', []) || 
            isPublic(p)
          );
        }
        // editor / owner のみ書き込み可（viewer は読み取り専用・docs/15 §4）。
        // 後方互換: roles 未設定なら ownerId / memberIds にフォールバック。
        function canWriteWorkspace() {
          let p = parentProject();
          let pAfter = parentProjectAfter();
          let proj = p != null ? p : pAfter;
          let role = proj != null ? proj.get('roles', {}).get(request.auth.uid, '') : '';
          let hasRoles = proj != null && proj.get('roles', {}).size() > 0;
          return isSignedIn() && proj != null && (
            role == 'owner' || role == 'editor' ||
            (!hasRoles && (
              request.auth.uid == proj.ownerId ||
              request.auth.uid in proj.get('memberIds', [])
            ))
          );
        }

        allow read: if canReadWorkspace();
        allow create, update, delete: if canWriteWorkspace();
        
        match /{document=**} {
          allow read: if canReadWorkspace();
          allow write: if canWriteWorkspace();
        }
      }

      /* ---- Project Work Files & Activities (Phase 26) ---- */
      match /workFiles/{workFileId} {
        allow read, write: if isSignedIn(); // TODO: lock to project members
        
        match /versions/{versionId} {
          allow read, write: if isSignedIn();
        }
      }
      match /activities/{activityId} {
        allow read, write: if isSignedIn(); // TODO: lock to project members
      }

      match /journals/{journalId} {
        function parentProject() {
          let docRef = get(/databases/$(database)/documents/projects/$(projectId));
          return docRef != null ? docRef.data : null;
        }
        function canReadJournal() {
           let p = parentProject();
           return isSignedIn() && p != null && (
             request.auth.uid == p.ownerId ||
             request.auth.uid in p.get('memberIds', []) ||
             isPublic(p)
           );
        }
        function canWriteJournal() {
           let p = parentProject();
           return isSignedIn() && p != null && (
             request.auth.uid == p.ownerId ||
             request.auth.uid in p.get('memberIds', [])
           );
        }
        allow read: if canReadJournal();
        allow write: if canWriteJournal();
      }

      /* ---- Research & Memo リサーチボード（無限キャンバス、1プロジェクト=1doc） ---- */
      match /research/{researchDocId} {
        function parentProjectR() {
          let docRef = get(/databases/$(database)/documents/projects/$(projectId));
          return docRef != null ? docRef.data : null;
        }
        function canReadResearch() {
           let p = parentProjectR();
           return isSignedIn() && p != null && (
             request.auth.uid == p.ownerId ||
             request.auth.uid in p.get('memberIds', []) ||
             isPublic(p)
           );
        }
        function canWriteResearch() {
           let p = parentProjectR();
           return isSignedIn() && p != null && (
             request.auth.uid == p.ownerId ||
             request.auth.uid in p.get('memberIds', [])
           );
        }
        allow read: if canReadResearch();
        allow write: if canWriteResearch();
      }

      match /assets/{assetId} {
        function parentProjectForAsset() { 
          let docRef = get(/databases/$(database)/documents/projects/$(projectId));
          return docRef != null ? docRef.data : null;
        }
        function canReadAsset() {
           let p = parentProjectForAsset();
           return isSignedIn() && p != null && (
             request.auth.uid == p.ownerId ||
             request.auth.uid in p.get('memberIds', []) || 
             isPublic(p)
           );
        }
        function canWriteAsset() {
           let p = parentProjectForAsset();
           return isSignedIn() && p != null && (
             request.auth.uid == p.ownerId ||
             request.auth.uid in p.get('memberIds', [])
           );
        }
        allow read: if canReadAsset();
        allow write: if canWriteAsset();
      }

      /* ---- Project Site (ProjectSite = 公開サイト本体 / SEKKEIYA Chat 編集対象) ---- */
      // /projects/{projectId}/site/main（単一ドキュメント）。docs/09 §3 / docs/10
      match /site/{docId} {
        function parentProjectForSite() {
          let docRef = get(/databases/$(database)/documents/projects/$(projectId));
          return docRef != null ? docRef.data : null;
        }
        function canReadSite() {
          let p = parentProjectForSite();
          return isSignedIn() && p != null && (
            request.auth.uid == p.ownerId ||
            request.auth.uid in p.get('memberIds', []) ||
            isPublic(p)
          );
        }
        function canWriteSite() {
          let p = parentProjectForSite();
          return isSignedIn() && p != null && (
            request.auth.uid == p.ownerId ||
            request.auth.uid in p.get('memberIds', [])
          );
        }
        allow read: if canReadSite();
        allow write: if canWriteSite();
      }

      /* ---- Project 共同チャット（SEKKEIYA OS / Agent 常駐チャット）----
         docs/chat_unification_firestore_rules_draft（desktop）準拠。
         /projects/{projectId}/chatMessages            = 既定「メインチャット」
         /projects/{projectId}/chatTopics/{topicId}    = 複数トピック（＋/messages）
         メンバー（ownerId + memberIds）が read/write 可。
         senderUid は本人 / 'sekkeiya-ai'（AI）/ 'system'（進行通知）を許可。
         ※メンバーによる AI/system なりすましは可能。将来 Cloud Function 経由で封じる。 */
      function chatParentProject() {
        let docRef = get(/databases/$(database)/documents/projects/$(projectId));
        return docRef != null ? docRef.data : null;
      }
      function isProjectChatMember() {
        let p = chatParentProject();
        return isSignedIn() && p != null && (
          request.auth.uid == p.ownerId ||
          request.auth.uid in p.get('memberIds', [])
        );
      }
      function validChatSender() {
        let s = request.resource.data.senderUid;
        return s == request.auth.uid || s == 'sekkeiya-ai' || s == 'system';
      }

      match /chatMessages/{messageId} {
        allow read:   if isProjectChatMember();
        allow create: if isProjectChatMember() && validChatSender();
        allow update, delete: if false; // 履歴は不変
      }

      match /chatTopics/{topicId} {
        // トピック一覧・作成・lastMessage 更新・削除はメンバー。
        allow read, create, update, delete: if isProjectChatMember();

        match /messages/{messageId} {
          allow read:   if isProjectChatMember();
          allow create: if isProjectChatMember() && validChatSender();
          allow update, delete: if false; // 履歴は不変
        }
      }

      match /sections/{sectionId} {
        allow read, write: if isSignedIn();

        match /items/{itemId} {
          allow read, write: if isSignedIn();
        }
      }      // Rhino/Blender 版管理
      match /designFileMeta/{appType} {
        allow read, write: if isSignedIn();
      }

      match /designFiles/{fileId} {
        allow read, write: if isSignedIn();
      }

      /* ---- Schedules & Tasks (SchedulesTasksContent / SchedulesTasksList) ---- */
      match /schedules/{scheduleId} {
        allow read, write: if isSignedIn(); // TODO: lock to project members
      }
      match /tasks/{taskId} {
        allow read, write: if isSignedIn(); // TODO: lock to project members
      }
    }

    // ─── 3DSC: Furniture Templates ───────────────────────────────────────────
    match /furnitureTemplates/{templateId} {
      // 公開テンプレートは誰でも閲覧可（Galleryフィード用）
      allow read: if isPublic(resource.data) || (
        isSignedIn() && resource.data.createdBy == request.auth.uid
      );
      // 作成: サインイン済み & createdByが自分
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid;
      // 更新・削除: 自分のテンプレートのみ
      allow update, delete: if isSignedIn() &&
        resource.data.createdBy == request.auth.uid;
    }

    // ─── Presentation Templates ───────────────────────────────────────────────
    match /presentationTemplates/{templateId} {
      // 適用時の usageCount +1 のみを許す更新か（他ユーザーの公開テンプレ適用のため）
      function isUsageIncrementOnly() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']) &&
          request.resource.data.usageCount == resource.data.usageCount + 1;
      }
      // 公開テンプレートまたは自分のものは読み取り可
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' ||
        resource.data.createdBy == request.auth.uid
      );
      // 作成: サインイン済み & createdByが自分
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid;
      // 更新: 本人（createdBy 改変不可）、または誰でも usageCount +1 のみ
      allow update: if isSignedIn() && (
        (resource.data.createdBy == request.auth.uid &&
         request.resource.data.createdBy == resource.data.createdBy) ||
        isUsageIncrementOnly()
      );
      // 削除: 自分のテンプレートのみ
      allow delete: if isSignedIn() &&
        resource.data.createdBy == request.auth.uid;
    }

    /* ======================================================
     * ★ Teams
     *    /teams/{teamId}
     *    /teams/{teamId}/invitations/{invitationId}
     * ==================================================== */
    match /teams/{teamId} {
      function isTeamMember() {
        return isSignedIn() && request.auth.uid in resource.data.get('memberIds', []);
      }
      function isTeamOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      // 公開チームは誰でも閲覧可、非公開はメンバーのみ
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' || isTeamMember()
      );

      // 作成: サインイン済み & ownerId が自分 & 自分が memberIds に含まれる
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // 更新: オーナーのみ設定変更可 / メンバーは memberIds (参加・退出) のみ変更可
      // 招待承認: invitee が自分を memberIds に追加する（まだメンバーでない場合）
      allow update: if isTeamOwner() || (
        isTeamMember()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt'])
      ) || (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt'])
        && request.auth.uid in request.resource.data.memberIds
        && !(request.auth.uid in resource.data.get('memberIds', []))
      );

      // 削除: オーナーのみ
      allow delete: if isTeamOwner();

      // invitations サブコレクション
      match /invitations/{invitationId} {
        // チームメンバーは招待一覧を閲覧可
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;

        // 招待作成: チームオーナーのみ
        allow create: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId
          && request.resource.data.invitedBy == request.auth.uid;

        // 状態更新 (accepted/declined): 招待した本人 or inviteeUid
        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.invitedBy ||
          request.auth.uid == resource.data.inviteeUid
        );

        // 削除 (取り消し): オーナーのみ
        allow delete: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId;
      }

      /* ---- Team Site (チームサイト本体＝SiteOwner 2層モデル, docs/15 §8) ---- */
      // /teams/{teamId}/site/main。公開ページのため読み取りは公開、
      // 編集はチームメンバー（memberIds に含まれる）のみ。
      match /site/{docId} {
        allow read: if true;
        allow write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.get('memberIds', []);
      }
    }

    /* ======================================================
     * ★ AIメモリー（長期記憶・2スコープ） — desktop docs/21
     *    users/{uid}/aiMemory    = 人物像（本人のみ）
     *    projects/{pid}/aiMemory = 案件の決定・制約（メンバー共有）
     *    どちらも予約ID `_digest` にAI注入用ダイジェストを持つ
     * ==================================================== */
    match /users/{userId}/aiMemory/{memId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /projects/{projectId}/aiMemory/{memId} {
      function memProj() { return get(/databases/$(database)/documents/projects/$(projectId)).data; }
      allow read, write: if isSignedIn() && (
        request.auth.uid in memProj().get('memberIds', []) ||
        request.auth.uid == memProj().ownerId
      );
    }

    /* ======================================================
     * ★ User Notifications
     *    /users/{uid}/notifications/{notifId}
     * ==================================================== */
    match /users/{userId}/notifications/{notifId} {
      // 本人のみ読み書き可
      allow read: if isSignedIn() && request.auth.uid == userId;
      // 作成: Cloud Functions 経由（クライアントからも許容: 招待送信時に書き込む）
      allow create: if isSignedIn();
      // 更新 (既読マーク): 本人のみ
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    /* ======================================================
     * ★ Stripe 決済（firestore-stripe-payments 拡張機能）
     *    docs: https://github.com/invertase/stripe-firebase-extensions
     *    - customers/{uid}            : 顧客本体（本人のみ read）
     *    - customers/{uid}/checkout_sessions : クライアントが作成→拡張機能がurl書き戻し
     *    - customers/{uid}/subscriptions     : サブスク状態（拡張機能が書込み）
     *    - customers/{uid}/payments          : 単発決済=寄付（拡張機能が書込み）
     *    - products / products/{id}/prices   : Stripe商品（公開read。書込みは拡張機能のみ）
     * ==================================================== */
    match /customers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      // チェックアウト開始: 本人が自分の配下に作成・読み取り（urlの書き戻しを待つ）
      match /checkout_sessions/{id} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
      // サブスク・決済記録: 本人 read のみ（書込みは拡張機能=admin SDK）
      match /subscriptions/{id} {
        allow read: if isSignedIn() && request.auth.uid == uid;
      }
      match /payments/{id} {
        allow read: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // 管理者向け収益集計用: collectionGroup("payments") を横断で読む（/admin/revenue）。
    // 上の customers/{uid}/payments の本人read許可とは独立したルール。
    match /{path=**}/payments/{paymentId} {
      allow read: if isAdminUser();
    }

    // Stripe 商品/価格: 料金表示のため公開 read。書込みは拡張機能(admin)のみ。
    match /products/{id} {
      allow read: if true;
      match /prices/{priceId} {
        allow read: if true;
      }
      match /tax_rates/{taxId} {
        allow read: if true;
      }
    }

    /* ======================================================
     * ★ 寄付コメント（LP公開用）
     *    決済成功時に Cloud Function (admin) が approved:false で転記。
     *    管理者承認後 approved:true のものだけ公開表示。
     *    クライアントからの直接書込みは禁止（必ず決済を経由させる）。
     * ==================================================== */
    match /donationComments/{id} {
      // 公開: 承認済みのみ。管理者は未承認も閲覧可（承認画面用）。
      allow read: if resource.data.approved == true || isAdminUser();
      // 承認/取消は管理者が approved のみ変更可。新規作成は Function 専用、削除は管理者。
      allow update: if isAdminUser()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approved']);
      allow delete: if isAdminUser();
      allow create: if false;
    }

    /* ======================================================
     * ★ AI使用量トラッキング（方式A / 管理者APIモニター）
     *    書き込みは Cloud Function (admin SDK) 専用 → クライアント直書き禁止。
     *    読み取りは管理者のみ（集計は getAdminUsageSummary CF 経由を推奨）。
     * ==================================================== */
    match /usageLogs/{id} {
      allow read: if isAdminUser();
      allow write: if false;
    }
    match /usageDaily/{day} {
      allow read: if isAdminUser();
      allow write: if false;
    }

    /* ======================================================
     * ★ 開発バックログ（管理者「開発状況」画面）
     *    要求定義・要件定義の項目と進捗。管理者のみ読み書き。
     * ==================================================== */
    match /devBacklog/{itemId} {
      allow read, write: if isAdmin();
    }

  }
}
