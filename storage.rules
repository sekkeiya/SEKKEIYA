rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /* ---------- helpers ---------- */
    function isSignedIn() { return request.auth != null; }
    function isMe(uid) { return isSignedIn() && request.auth.uid == uid; }



    // ✅ contentType が空/不明でも事故らないように許容範囲を広げる
    function isAllowedMainModelContentType() {
      return request.resource.contentType.matches('application/.*')
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType.matches('model/.*')
        || request.resource.contentType.matches('image/.*');
    }

    /* ---------- Models (legacy/existing) ---------- */
    match /models/{uid}/{modelId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isMe(uid);
    }

    /* ---------- Master Assets (Global SSOT: /assets) ---------- */
    match /assets/{assetId}/{allPaths=**} {
      allow read: if true;
      allow create: if isSignedIn() 
                    && request.resource.metadata != null 
                    && request.resource.metadata.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() 
                            && (
                               (resource != null && resource.metadata != null && resource.metadata.ownerId == request.auth.uid)
                               || (
                                 firestore.exists(/databases/(default)/documents/assets/$(assetId))
                                 && (
                                   firestore.get(/databases/(default)/documents/assets/$(assetId)).data.authorId == request.auth.uid 
                                   || firestore.get(/databases/(default)/documents/assets/$(assetId)).data.ownerId == request.auth.uid
                                 )
                               )
                            );
    }

    match /users/{uid}/models/{modelId}/{allPaths=**} {
      allow read, write: if isMe(uid);
    }

    match /users/{uid}/generated_models/{allPaths=**} {
      allow read, write: if isMe(uid);
    }

    match /thumbnails/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if isMe(uid);
    }

    /* ---------- Articles (existing) ---------- */
    match /articles/{all=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /officialArticles/{allPaths=**} {
      allow read: if true;
    }

    match /officialArticles/covers/{uid}/{fileName} {
      allow read: if true;
      allow create, update: if isMe(uid)
                            && request.resource.size < 10 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');
      allow delete: if isMe(uid);
    }

    match /officialArticles/media/{uid}/{articleId}/{fileName} {
      allow read: if true;
      allow create, update: if isMe(uid)
                            && request.resource.size < 50 * 1024 * 1024
                            && (
                              request.resource.contentType.matches('image/.*') ||
                              request.resource.contentType.matches('video/.*') ||
                              request.resource.contentType == 'application/pdf'
                            );
      allow delete: if isMe(uid);
    }

    match /officialArticles/inline/{uid}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isMe(uid)
                            && request.resource.size < 50 * 1024 * 1024
                            && (
                              request.resource.contentType.matches('image/.*') ||
                              request.resource.contentType.matches('video/.*') ||
                              request.resource.contentType == 'application/pdf'
                            );
      allow delete: if isMe(uid);
    }

    /* ---------- Materials ---------- */
    match /materials/{materialId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }



    /* ---------- AI Drive ---------- */
    match /drive/{userId}/{allPaths=**} {
      allow read, write: if isMe(userId);
    }

    /* ---------- Design Files (Rhino/Blender) ---------- */
    match /designFiles/{appType}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /* ---------- Templates ---------- */
    match /templates/{uid}/{fileName} {
      allow read, write, delete: if isMe(uid);
    }

    /* ---------- Work Files (SSOT Architecture) ---------- */
    match /workFiles/{projectId}/{workFileId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    /* ---------- Project Assets (Models, etc.) ---------- */
    match /projects/{projectId}/assets/{assetId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    /* ---------- 3DSL Renders (still images / videos from Layout) ---------- */
    match /projects/{projectId}/renders/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    /* ---------- Project Journals (Attachments) ---------- */
    match /projects/{projectId}/journals/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    /* ---------- Installers (public download, signed-in upload) ---------- */
    match /installers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* ---------- fallback（✅ 必ず一番最後） ---------- */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
